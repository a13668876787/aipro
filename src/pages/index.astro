---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterScript from '../components/FilterScript.astro';
import { allTools, formatDate, toJson } from '../lib/content';

const daily = (await getCollection('daily')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const opportunities = await getCollection('opportunities');
const library = await getCollection('library');
const latest = daily[0];
const topScripts = daily.slice(0, 3);
const topTools = allTools.slice(0, 6);
const weekday = new Intl.DateTimeFormat('zh-CN', { weekday: 'long' }).format(latest.data.date);
const updatedAt = '今日 09:10 人工精选';
const copyPrompt = `请把“AI 今日雷达 Pro”的今日信号改成 60 秒短视频：开头3秒、正文3点、风险提醒、评论区CTA。今日主题：${latest.data.videoTitle}`;
const copyScript = (item) => `【选题标题】${item.data.videoTitle}

【开头3秒】${item.data.hook3s}

【60秒口播】${item.data.script60s}

【画面建议】
${item.data.shotList.map((shot, index) => `${index + 1}. ${shot}`).join('\n')}

【评论区CTA】${item.data.commentCTA}

【私信回复】${item.data.dmReply}

【可卖产品/服务】${item.data.sellableOffer}

【风险提醒】${item.data.risk}

【来源】${item.data.sourceName}：${item.data.sourceUrl}`;
---

<BaseLayout title="AI 今日雷达 Pro · 资讯、工具、机会库">
  <main>
    <section class="hero">
      <div class="hero-copy">
        <span class="eyebrow">第一性原理 · 对抗式审查 · {formatDate(latest.data.date)} {weekday}</span>
        <h1>每日 AI 资讯：今天最值得看的 3 条 AI 信号</h1>
        <p>先看清今天发生了什么、来源在哪里、风险是什么；再把高价值资讯顺手变成可拍短视频文案、引流话术和变现方向。</p>
        <div class="hero-actions">
          <a class="button primary" href={`${import.meta.env.BASE_URL}daily/${latest.id}/`}>看今日资讯详情</a>
          <a class="button" href={`${import.meta.env.BASE_URL}opportunities/`}>看赚钱机会库</a>
          <button class="button" data-copy={copyPrompt}>复制今日短视频提示词</button>
        </div>
      </div>
      <figure class="hero-media">
        <img src={`${import.meta.env.BASE_URL}assets/hero-radar.png`} alt="AI 今日雷达 Pro 主视觉" />
        <figcaption>AI 资讯 · 工具目录 · 机会验证库</figcaption>
      </figure>
    </section>

    <section class="stats" aria-label="站点状态">
      <article class="stat"><strong>{formatDate(latest.data.date)}</strong><span>今日日期</span></article>
      <article class="stat"><strong>{updatedAt}</strong><span>最后更新</span></article>
      <article class="stat"><strong>{topScripts.length}</strong><span>条重点资讯</span></article>
      <article class="stat"><strong>{allTools.length}</strong><span>个 AI 工具</span></article>
    </section>

    <section class="source-strip">
      <div>
        <span class="section-kicker">Sources</span>
        <h2>今日内容从哪来</h2>
      </div>
      <p>人工精选官方发布、产品页、GitHub/开发者资料、可信媒体报道和真实工具入口；社媒热度只做选题参考，不单独当事实来源。</p>
      <a class="button" href={`${import.meta.env.BASE_URL}daily/`}>查看每日归档</a>
    </section>

    <section class="section-head">
      <div>
        <span class="section-kicker">Today News</span>
        <h2>今日 AI 资讯 Top 3</h2>
      </div>
      <p>每条先是资讯判断，再附带可拍文案。拍之前先打开来源，别把趋势讲成确定收益。</p>
    </section>
    <section class="script-grid">
      {topScripts.map((item) => (
        <article class="script-card">
          <div class="tag-row"><span class="tag">{item.data.category}</span><span class="tag warn">{item.data.impact}影响</span></div>
          <h3>{item.data.title}</h3>
          <p>{item.data.summary}</p>
          <dl>
            <div><dt>为什么重要</dt><dd>{item.data.review.mechanism}</dd></div>
            <div><dt>今天能做</dt><dd>{item.data.action}</dd></div>
          </dl>
          <div class="script-block">
            <strong>可拍文案：{item.data.videoTitle}</strong>
            <p class="hook">{item.data.hook3s}</p>
            <p>{item.data.script60s}</p>
          </div>
          <div class="script-block">
            <strong>画面建议</strong>
            <ol>{item.data.shotList.map((shot) => <li>{shot}</li>)}</ol>
          </div>
          <div class="script-cta">
            <strong>评论区 CTA</strong>
            <p>{item.data.commentCTA}</p>
          </div>
          <p class="risk-line">资讯风险：{item.data.risk}</p>
          <div class="card-actions">
            <button class="primary" data-copy={copyScript(item)} data-copy-kind="copy_script">复制完整脚本</button>
            <button data-copy={item.data.commentCTA} data-copy-kind="copy_cta">复制 CTA</button>
            <a href={`${import.meta.env.BASE_URL}daily/${item.id}/`}>详情</a>
            <a href={item.data.sourceUrl} target="_blank" rel="noopener">来源</a>
          </div>
        </article>
      ))}
    </section>

    <section class="section-head">
      <div>
        <span class="section-kicker">Opportunity Engine</span>
        <h2>工具、机会、资料一体化</h2>
      </div>
      <p>首页负责吸引人，工具目录负责留住人，机会库负责转化人，资料库负责长期积累。</p>
    </section>
    <section class="grid-3">
      <article class="panel">
        <div class="cover"><img src={`${import.meta.env.BASE_URL}assets/tools-cover.png`} alt="AI 工具目录" /><span>Tools</span></div>
        <h3>AI 工具目录</h3>
        <p>按用途、价格、难度、适合人群和变现方向筛选。不是推荐榜，而是工具采用审查。</p>
        <a class="button primary" href={`${import.meta.env.BASE_URL}tools/`}>进入工具目录</a>
      </article>
      <article class="panel">
        <div class="cover"><img src={`${import.meta.env.BASE_URL}assets/opportunities-cover.png`} alt="AI 赚钱机会库" /><span>Opportunities</span></div>
        <h3>赚钱机会库</h3>
        <p>每个机会都有 7 天验证步骤、失败点、受益者和风险，不写确定收益。</p>
        <a class="button primary" href={`${import.meta.env.BASE_URL}opportunities/`}>进入机会库</a>
      </article>
      <article class="panel">
        <h3>第一性原理资料库</h3>
        <p>沉淀方法论、工具风险清单、内容转服务路径和静态站打法。</p>
        <div class="tag-row">
          {library.map((item) => <span class="tag">{item.data.pillar}</span>)}
        </div>
        <a class="button primary" href={`${import.meta.env.BASE_URL}library/`}>进入资料库</a>
      </article>
    </section>

    <section class="filters">
      <input data-search-input type="search" placeholder="搜索首页精选工具：ChatGPT、编程、自动化、短视频..." />
      <div class="filter-group">
        <button class="filter-chip active" data-filter-category="全部">全部</button>
        {[...new Set(topTools.map((tool) => tool.category))].map((category) => <button class="filter-chip" data-filter-category={category}>{category}</button>)}
      </div>
      <span data-result-count>显示 {topTools.length} 条</span>
    </section>
    <section class="content-grid">
      {topTools.map((tool) => (
        <article class="content-card" data-card data-id={tool.id} data-title={tool.name} data-category={tool.category} data-difficulty={tool.difficulty} data-audience={tool.audience} data-risk={tool.risk}>
          <span class="tag">{tool.category}</span>
          <h3>{tool.name}</h3>
          <p>{tool.useCase}</p>
          <dl>
            <div><dt>变现用途</dt><dd>{tool.monetization}</dd></div>
            <div><dt>风险</dt><dd>{tool.risk}</dd></div>
          </dl>
          <div class="card-actions">
            <a class="primary" href={tool.url} target="_blank" rel="noopener">官网</a>
            <button data-save={tool.id}>收藏</button>
            <button data-read={tool.id}>标为已读</button>
          </div>
        </article>
      ))}
    </section>
    <section class="saved-panel">
      <span class="section-kicker">Local Topic Pool</span>
      <h2>我的选题池</h2>
      <div class="saved-list" data-saved-list></div>
    </section>
  </main>
  <script type="application/json" id="radar-data" set:html={toJson({ latest: latest.data.title, date: formatDate(latest.data.date) })} />
  <FilterScript />
</BaseLayout>
