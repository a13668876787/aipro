---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('opportunities');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} · AI 赚钱机会库`}>
  <article class="article">
    <span class="eyebrow">{post.data.type} · {post.data.difficulty}</span>
    <h1>{post.data.title}</h1>
    <p>{post.data.monetizationPath}</p>
    <section class="review-grid">
      <article><strong>真实机制</strong><p>{post.data.review.mechanism}</p></article>
      <article><strong>谁受益</strong><p>{post.data.review.whoBenefits}</p></article>
      <article><strong>你承担的风险</strong><p>{post.data.review.userRisk}</p></article>
      <article><strong>验证方式</strong><p>{post.data.review.verification}</p></article>
      <article><strong>失败点</strong><p>{post.data.review.failureMode}</p></article>
      <article><strong>短视频角度</strong><p>{post.data.videoAngle}</p></article>
    </section>
    <h2>7 天验证步骤</h2>
    <ol>
      {post.data.sevenDayTest.map((step) => <li>{step}</li>)}
    </ol>
    <Content />
  </article>
</BaseLayout>
